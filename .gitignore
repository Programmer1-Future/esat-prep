# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

node_modules
dist
dist-ssr
*.local

# Environment secrets
.env
.env.*
!.env.example

# Editor directories and files
.vscode/*
!.vscode/extensions.json
.idea
.DS_Store
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# Diagram extraction working artifacts. public/diagrams/ is the shipped set and IS
# tracked; these are the staging copy, the pre-swap backup, the OCR cache and the
# review contact sheets — all reproducible from scripts/extract_diagrams.py.
public/diagrams_v2/
public/diagrams_old/
scripts/.ocr_cache/
scripts/__pycache__/
diagram-review/

# Fabrication-audit working data: Gemini transcriptions of the source papers, cached
# so a re-run never re-buys tokens. Reproducible from scripts/gemini_transcribe.py,
# and large — the scripts are tracked, the fetched data is not.
# Use /** (not a bare directory rule) so negation can re-include durable corrections —
# git cannot re-include a file if a parent directory itself is excluded.
scripts/.fabrication_audit/**
!scripts/.fabrication_audit/gemini/
!scripts/.fabrication_audit/gemini/**/
!scripts/.fabrication_audit/gemini/**/retry_pro.json
!scripts/.fabrication_audit/gemini/**/zzz_pdf_corrections.json

# Browser-automation scratch (Playwright MCP snapshots and verification screenshots)
.playwright-mcp/
/*.png

# Local past-paper PDFs (not shipped; keep question-bank/source-pdfs/ via .gitkeep)
question-bank/source-pdfs/*.pdf
